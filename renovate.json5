{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  enabledManagers: ["github-actions"],
  branchPrefix: "Garoon-renovate/",
  labels: ["renovate"],
  timezone: "Asia/Tokyo",
  minimumReleaseAge: "0 days", // to test
  dependencyDashboard: true,
  automergeSchedule: ["at any time"], // testing
  prConcurrentLimit: 0, // Update later
  prHourlyLimit: 0,
  prHourlyLimit: 0,
  semanticCommits: "disabled",
  automergeStrategy: "merge-commit",
  platformAutomerge: false,
  lockFileMaintenance: {
    enabled: true,
    automerge: false,
    schedule: ["every 3 months on the first day of the month"],
    branchTopic: "lock-file-maintenance-{{packageFile}}",
    commitMessageExtra: "({{packageFile}})",
  },
  "packageRules": [
    /* ------------------------------------------
      GitHub Actions
    ------------------------------------------  */

    // Test rule: branchSuffix for actions/checkout
    {
      matchManagers: ["github-actions"],
      matchDepTypes: ["action"],
      matchPackageNames: ["actions/checkout"],
      branchName: "{{branchPrefix}}{{branchTopic}}-with-e2e",
      automerge: false,
      labels: ["testing"],
    },

    // [temporary stop] Auto-merge major/minor/patch updates for trusted actions
    {
      matchManagers: ["github-actions"],
      matchDepTypes: ["action"],
      automerge: false,
      pinDigests: true,
      matchPackageNames: [
        "actions/**",
        "cybozu**",
        "aws-actions/**",
        "docker/**",
        "ruby/**"
      ],
    },

    // Third-party actions: manual review, pin digest
    {
      matchManagers: ["github-actions"],
      matchDepTypes: ["action"],
      matchPackageNames: [
        "!actions/**",
        "!cybozu**",
        "!aws-actions/**",
        "!docker/**",
        "!ruby/**"
      ],
      automerge: false,
      pinDigests: true
    },

    // Disable runtime version updates
    {
      matchManagers: ["github-actions"],
      matchDepNames: [
        "node",
        "python",
        "java",
        "ruby",
        "go"
      ],
      enabled: false,
    },

    // Disable Docker images updates (MySQL, AWS ECR, Oracle Container Registry)
    {
      matchManagers: ["github-actions"],
      matchDepTypes: ["service", "container"],
      matchPackageNames: [
        "mysql",
        "/\\.dkr\\.ecr\\..*\\.amazonaws\\.com//",
        "/container-registry\\.oracle\\.com/",
      ],
      enabled: false,
    }
  ],
  customManagers: [],
}
